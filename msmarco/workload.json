{
  "description": "High-Performance Binary MSMARCO Cohere Ingestion Workload",
  "indices": [
    {
      "name": "{{ target_index_name }}",
      "body": "{{ target_index_body | default('indices/index.json')}}"
    }
  ],
  "test_procedures": [
    {
      "name": "create-index-only",
      "description": "Create index without loading data",
      "default": false,
      "schedule": [
        {
          "operation": {
            "operation-type": "delete-index",
            "only-if-exists": true,
            "index": "{{ target_index_name }}"
          }
        },
        {
          "operation": {
            "operation-type": "create-index",
            "index": "{{ target_index_name }}"
          }
        }
      ]
    },
    {
      "name": "bulk-ingest-only",
      "description": "Load data into existing index",
      "default": false,
      "schedule": [
        {
          "name": "bulk-ingestion-phase",
          "operation": {
            "operation-type": "bulk",
            "param-source": "msmarco-fvec-bulk-source",
            "file_path": "{{ target_index_bulk_index_data_set_path }}",
            "num_vectors": {{ num_vectors | default(1000000) }},
            "bulk_size": {{ target_index_bulk_size | default(5000) }},
            "index": "{{ target_index_name }}"
          },
          "clients": {{ target_index_bulk_indexing_clients | default(8) }}
        }
      ]
    },
    {
      "name": "force-merge",
      "description": "Force merge index to specified number of segments",
      "default": false,
      "schedule": [
        {
          "operation": {
            "operation-type": "force-merge",
            "index": "{{ target_index_name }}",
            "request-timeout": {{ target_index_force_merge_timeout | default(7200) }},
            "mode": "polling",
            "max-num-segments": {{ target_index_max_num_segments | default(1) }},
            "include-in-results_publishing": true
          }
        }
      ]
    },
    {
      "name": "refresh",
      "description": "Refresh indexes",
      "default": false,
      "schedule": [
        {
          "operation": {
            "operation-type": "refresh",
            "index": "{{ target_index_name }}",
            "retries": 100
          }
        }
      ]
    },
    {
      "name": "vector-search",
      "default": true,
      "description": "Perform only vector search on previously indexed cluster, skipping warmup-indices task.",
      "schedule": [
        {
          "name": "vector-search-prod-queries",
          "operation": {
            "name": "vector-search-prod-queries",
            "operation-type": "vector-search",
            "param-source": "random-vector-search-param-source",
            "index_name": "{{ target_index_name }}",
            "num_vectors": {{ num_vectors | default(1000000) }},
            "detailed-results": true,
            "field": "{{ target_field_name }}",
            "ground_truth_file": "{{ ground_truth_file }}",
            "queries_file": "{{ queries_file }}",
            "id-field-name": "{{ id_field_name | default('_id') }}",
            "repetitions": {{ number_of_repetitions | default(1) }},
            "k": {{ query_k | default(10) }},
            {% if query_max_distance is defined %}
            "max_distance": {{ query_max_distance }},
            {% endif %}
            {% if query_min_score is defined %}
            "min_score": {{ query_min_score }},
            {% endif %}
            {% if oversample_factor is defined %}
            "oversample_factor": {{ oversample_factor }},
            {% endif %}
            "body": "{{ query_body | safe }}"
          },
          "clients": {{ search_clients | default(1) }},
          {% if time_period is defined %}
          "warmup-time-period": {{ warmup_time_period | default(60) }},
          "time-period": {{ time_period }}
          {% else %}
          "warmup-iterations": {{ warmup_iterations | default(0) }},
          "iterations": {{ iterations | default(1000) }}
          {% endif %}
        }
      ]
    }
  ]
}