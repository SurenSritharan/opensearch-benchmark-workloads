{
  "description": "High-Performance Binary MSMARCO Cohere Ingestion Workload",
  "indices": [
    {
      "name": "{{ target_index_name | default('cohere-msmarco-1024') }}",
      "body": "{{ target_index_body | default('indices/index.json') }}"
    }
  ],
  "test_procedures": [
    {
      "name": "create-index-only",
      "description": "Create index without loading data",
      "default": false,
      "schedule": [
        {
          "operation": {
            "operation-type": "delete-index",
            "only-if-exists": true,
            "index": "{{ target_index_name | default('cohere-msmarco-1024') }}"
          }
        },
        {
          "operation": {
            "operation-type": "create-index",
            "index": "{{ target_index_name | default('cohere-msmarco-1024') }}"
          }
        }
      ]
    },
    {
      "name": "bulk-ingest-only",
      "description": "Load data into existing index",
      "default": false,
      "schedule": [
        {
          "name": "bulk-ingestion-phase",
          "operation": {
            "operation-type": "bulk",
            "param-source": "msmarco-fvec-bulk-source",
            "file_path": "/datasets/msmarco/cohere_msmarco_base.fvec",
            "bulk_size": 1000,
            "index": "{{ target_index_name | default('cohere-msmarco-1024') }}"
          },
          "clients": 8
        }
      ]
    },
    {
      "name": "create-index-and-load",
      "description": "Create index and load data",
      "default": false,
      "schedule": [
        {
          "operation": {
            "operation-type": "delete-index",
            "only-if-exists": true,
            "index": "{{ target_index_name | default('cohere-msmarco-1024') }}"
          }
        },
        {
          "operation": {
            "operation-type": "create-index",
            "index": "{{ target_index_name | default('cohere-msmarco-1024') }}"
          }
        },
        {
          "name": "bulk-ingestion-phase",
          "operation": {
            "operation-type": "bulk",
            "param-source": "msmarco-fvec-bulk-source",
            "file_path": "/datasets/msmarco/cohere_msmarco_base.fvec",
            "bulk_size": 1000,
            "index": "{{ target_index_name | default('cohere-msmarco-1024') }}"
          },
          "clients": 8
        },
        {
          "name": "refresh-index",
          "operation": {
            "operation-type": "refresh",
            "index": "{{ target_index_name | default('cohere-msmarco-1024') }}"
          }
        },
        {
          "name": "force-merge",
              "operation": {
                "operation-type": "force-merge",
                "index": "{{ target_index_name | default('cohere-msmarco-1024') }}",
                "max-num-segments": {{ target_index_max_num_segments | default(1) }},
                "request-timeout": 7200
              }
        }
      ]
    },
    {
      "name": "force-merge",
      "description": "Force merge index to specified number of segments",
      "default": false,
      "schedule": [
        {
          "operation": {
            "operation-type": "force-merge",
            "index": "{{ target_index_name | default('cohere-msmarco-1024') }}",
            "max-num-segments": {{ target_index_max_num_segments | default(1) }},
            "request-timeout": 7200
          }
        }
      ]
    },
    {
      "name": "refresh",
      "description": "Refresh indexs",
      "default": false,
      "schedule": [
        {
          "operation": {
            "operation-type": "refresh",
            "index": "{{ target_index_name | default('cohere-msmarco-1024') }}",
            "max-num-segments": {{ target_index_max_num_segments | default(1) }},
            "request-timeout": 7200
          }
        }
      ]
    },
    {
      "name": "vector-search",
      "default": true,
      "description": "Perform only vector search on previously indexed cluster, skipping warmup-indices task.",
      "schedule": [
        {
          "name": "vector-search-prod-queries",
          "operation": {
            "name": "vector-search-prod-queries",
            "operation-type": "vector-search",
            "param-source": "random-vector-search-param-source",
            "index_name": "{{ target_index_name | default('cohere-msmarco-1024') }}",
            "detailed-results": true,
            "field": "{{ target_field_name | default('vector') }}",
            "data_set_format": "{{ query_data_set_format | default('bigann') }}",
            "data_set_path": "{{ query_data_set_path }}",
            "neighbors_data_set_path": "{{ neighbors_data_set_path }}",
            "neighbors_data_set_format": "{{ neighbors_data_set_format | default('bigann') }}",
            "query_count": {{ query_count | default(-1) }},
            "id-field-name": "{{ id_field_name | default('_id') }}",
            "repetitions": {{ number_of_repetitions | default(1) }},
            "dims": {{ target_index_dimension | default(1024) }},
            "k": {{ query_k }},
            "method_name": "{{ method_name | default('disk_ann') }}",
            "engine": "{{ engine | default('jvector') }}",
            "space_type": "{{ space_type | default('cosinesimil') }}",
            "body": "{{ query_body | default({}) | safe }}",
            "mode": "{{ mode | default('in_memory') }}"
            },
          "clients": {{ search_clients | default(1) }},
          "warmup-iterations": {{ warmup_iterations | default(0) }},
          "iterations": 1000
        }
      ]
    },
    {
      "name": "search",
      "default": false,
      "description": "Perform only vector search on previously indexed cluster, skipping warmup-indices task.",
      "schedule": [
        {
          "name": "search-prod-queries",
          "operation": {
            "name": "search-prod-queries",
            "operation-type": "search",
            "param-source": "random-vector-search-param-source",
            "index_name": "{{ target_index_name | default('cohere-msmarco-1024') }}",
            "detailed-results": true,
            "field": "{{ target_field_name | default('vector') }}",
            "data_set_format": "{{ query_data_set_format | default('bigann') }}",
            "data_set_path": "{{ query_data_set_path }}",
            "neighbors_data_set_path": "{{ neighbors_data_set_path }}",
            "neighbors_data_set_format": "{{ neighbors_data_set_format | default('bigann') }}",
            "query_count": {{ query_count | default(-1) }},
            "id-field-name": "{{ id_field_name | default('_id') }}",
            "repetitions": {{ number_of_repetitions | default(1) }},
            "dims": {{ target_index_dimension | default(1024) }},
            "k": {{ query_k }},
            "method_name": "{{ method_name | default('disk_ann') }}",
            "engine": "{{ engine | default('jvector') }}",
            "space_type": "{{ space_type | default('cosinesimil') }}",
            "body": "{{ query_body | default({}) | safe }}",
            "mode": "{{ mode | default('in_memory') }}"
            },
          "clients": {{ search_clients | default(1) }},
          "warmup-iterations": {{ warmup_iterations | default(0) }},
          "iterations": 1000
        }
      ]
    }
  ]
}