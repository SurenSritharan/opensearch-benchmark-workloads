{
  "name": "bulk-ingest-only",
  "description": "Load data into existing index (assumes index already exists)",
  "default": false,
  "schedule": [
    {
      "name": "bulk-ingestion-phase",
      "operation": {
        "operation-type": "bulk",
        "bulk-size": {{ bulk_size | default(1000) }},
        "ingest-percentage": {{ ingest_percentage | default(100) }}
        },
        "clients": {{ bulk_indexing_clients | default(8) }}
    }
  ]
}