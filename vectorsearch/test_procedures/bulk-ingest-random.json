{
  "name": "bulk-ingest-random",
  "description": "Ingest synthetic vectors generated via make_blobs — no corpus file required, supports any num_vectors",
  "default": false,
  "schedule": [
    {
      "operation": {
        "name": "random-vector-bulk",
        "operation-type": "bulk",
        "param-source": "random-vector-bulk-param-source",
        "index_name": "{{ target_index_name | default('target_index') }}",
        "field": "{{ target_field_name | default('target_field') }}",
        "bulk-size": {{ target_index_bulk_size | default(500) }},
        "num_vectors": {{ num_vectors }},
        "dims": {{ target_index_dimension | default(768) }},
        "num_centers": {{ num_centers | default(2000) }},
        "cluster_std": {{ cluster_std | default(0.5) }}
      },
      "clients": {{ target_index_bulk_indexing_clients | default(1) }}
    }
  ]
}
