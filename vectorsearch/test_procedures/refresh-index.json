{
    "name": "refresh-index",
    "description": "Refresh index",
    "default": false,
    "schedule": [
        {
            "operation": {
                "name": "refresh-target-index",
                "operation-type": "refresh",
                "retries": 100,
                "index": "{{ target_index_name | default('target_index') }}"
            }
        }
    ]
}
    